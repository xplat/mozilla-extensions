{
  "manifest_version": 3,
  "name": "Media Viewer",
  "version": "0.1.0",
  "description": "Local image viewer with xzgv-style UI, backed by a native host.",
  "browser_specific_settings": {
    "gecko": {
      "id": "media-viewer@xplat.github.io",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "http://127.7.203.98/*"
  ],
  "background": {
    "scripts": ["native-messaging.js", "background.js"]
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.js", "viewer.css"],
      "matches": ["<all_urls>"]
    }
  ]
}

{
  "manifest_version": 3,
  "name": "CBZ Comic Viewer",
  "version": "1.0.0",
  "description": "View CBZ comic archives directly in your browser. Supports stored and deflate-compressed pages.",

  "permissions": [
    "webRequest",
    "webNavigation",
    "tabs"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file:///*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.js", "viewer.css"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

{
  "manifest_version": 3,
  "name": "CBZ Comic Viewer",
  "version": "1.0.4",
  "description": "View CBZ comic archives directly in your browser. Supports stored and deflate-compressed pages.",

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "tabs",
    "nativeMessaging"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file:///*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Open CBZ file",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.js", "viewer.css", "bridge.html", "bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "cbz-viewer@extension",
      "strict_min_version": "109.0"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
